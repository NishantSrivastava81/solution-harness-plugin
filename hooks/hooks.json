{
    "hooks": {
        "SessionStart": [
            {
                "type": "command",
                "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/session-start.js",
                "timeout": 10
            }
        ],
        "Stop": [
            {
                "type": "command",
                "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/session-stop.js",
                "timeout": 10
            }
        ],
        "PreToolUse": [
            {
                "type": "command",
                "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/pre-tool-use.js",
                "timeout": 5
            }
        ],
        "PostToolUse": [
            {
                "type": "command",
                "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/post-tool-use.js",
                "timeout": 5
            }
        ]
    }
}